{
  "name": "real-estate-backend",
  "version": "1.0.0",
  "description": "Production-grade real estate backend (modular monolith, controller-service-model, MongoDB).",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "NODE_ENV=development nodemon src/server.js",
    "seed": "node scripts/seed-mongodb-production.js",
    "seed:clean": "node scripts/clear-db.js && node scripts/seed-mongodb-production.js",
    "lint": "echo \"No linter configured\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit"
